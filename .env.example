# ============================================================================
# MODÈLE de configuration — AUCUN SECRET RÉEL ICI.
# Copiez ce fichier en `.env` (ignoré par git) et remplacez les placeholders.
# ============================================================================

# --- Supabase ---
SUPABASE_URL=https://VOTRE_PROJET.supabase.co
VITE_SUPABASE_URL=https://VOTRE_PROJET.supabase.co
SUPABASE_PUBLISHABLE_KEY=VOTRE_CLE_PUBLISHABLE_ICI
VITE_SUPABASE_PUBLISHABLE_KEY=VOTRE_CLE_PUBLISHABLE_ICI
# ⚠ service_role contourne TOUTE la RLS : serveur uniquement, jamais côté client,
# jamais dans git.
SUPABASE_SERVICE_ROLE_KEY=VOTRE_CLE_SERVICE_ROLE_ICI

# --- Fournisseurs IA / OCR ---
MISTRAL_API_KEY=VOTRE_CLE_MISTRAL_ICI
GROQ_API_KEY=VOTRE_CLE_GROQ_ICI
GEMINI_API_KEY=VOTRE_CLE_GEMINI_ICI
DONUT_ENDPOINT=http://127.0.0.1:8501/parse
DONUT_TIMEOUT_MS=25000

# --- Envoi d'e-mails ---
# DEUX transports, essayés dans cet ordre :
#
#   1) API Brevo (HTTPS/443) — À PRIVILÉGIER EN PRODUCTION. Railway, Render et
#      la plupart des hébergeurs FILTRENT le port SMTP sortant : un envoi en 587
#      y meurt en ETIMEDOUT et le mail d'approbation d'inscription ne part
#      jamais. Le 443 passe toujours. Clé : https://app.brevo.com → SMTP & API.
#      ⚠ L'adresse FROM_EMAIL doit être un « sender » VALIDÉ dans le compte
#        Brevo, sinon l'API répond 400 (vérif : GET /v3/senders).
BREVO_API_KEY=
#
#   2) SMTP classique (nodemailer) — secours, et suffisant sur un réseau qui
#      laisse sortir le 587. Renseignez les 4 lignes SMTP_* puis REDÉMARREZ.
#      FROM_EMAIL doit être sur un domaine authentifié (SPF + DKIM + DMARC)
#      pour ne PAS tomber en spam.
#
# MAIL_TRANSPORT force un seul transport : brevo | smtp | auto (défaut).
# MAIL_TRANSPORT=auto
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=VOTRE_UTILISATEUR_SMTP_ICI
SMTP_PASS=VOTRE_MOT_DE_PASSE_SMTP_ICI
# SMTP_SECURE=false
# SMTP_TLS_REJECT_UNAUTHORIZED=true
FROM_EMAIL=contact@votre-domaine.ma
FROM_NAME=HisabPro

# --- Abonnements & quotas de scans ---
# Fournisseur de paiement. 'manual' = pas de paiement en ligne : le plan choisi
# est activé immédiatement, le règlement se fait hors application.
# Brancher Stripe/CMI plus tard = implémenter le provider puis poser sa valeur ici.
BILLING_PROVIDER=manual
# Politique en cas de PANNE du quota (RPC injoignable, migration non appliquée) :
#   false (défaut) → on laisse passer le scan et on journalise (un incident
#                    d'infra ne doit pas couper le produit) ;
#   true           → on bloque le scan. À activer quand la facturation devient
#                    contraignante (offre payante réellement vendue).
QUOTA_STRICT=false

# --- File de traitement documentaire (BullMQ / Redis) ---
# REDIS_URL=redis://127.0.0.1:6379   # décommentez après `npm run redis:up` pour le mode QUEUE
WORKER_CONCURRENCY=4
JOB_TIMEOUT_MS=120000
JOB_MAX_ATTEMPTS=3

# --- Tests E2E (local uniquement) ---
E2E_EMAIL=VOTRE_EMAIL_DE_TEST_ICI
E2E_PASSWORD=VOTRE_MOT_DE_PASSE_DE_TEST_ICI
E2E_ICE=000000000000000

# ── Approbation des inscriptions par l'administrateur ────────────────────────
# Un compte créé naît NON approuvé : get_user_cabinet() ne lui rend aucun
# cabinet, donc la RLS ne lui laisse voir aucune donnee tant qu'un admin n'a pas
# clique le lien recu par mail. Migration : 20260716120000_approbation_inscription.sql
#
# Secret qui signe les liens d'approbation (HMAC). OBLIGATOIRE : sans lui, la
# route /api/approve-user refuse de fonctionner (echec ferme). Le changer
# invalide tous les liens deja envoyes. Generer avec :
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APPROVAL_TOKEN_SECRET=

# Adresse qui recoit les demandes d'approbation.
ADMIN_APPROVAL_EMAIL=oussamakarmaoui7@gmail.com

# URL publique de l'app, pour construire un lien cliquable depuis l'e-mail.
# Sur Railway, RAILWAY_PUBLIC_DOMAIN est utilise automatiquement si APP_URL est
# vide. En local, laisser vide revient a http://localhost:3000.
APP_URL=

# Requis pour approuver (contourne la RLS). Deja necessaire ailleurs.
SUPABASE_SERVICE_ROLE_KEY=
